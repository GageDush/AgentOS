{
  "name": "agentos",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm dev:full",
    "dev:full": "pnpm --parallel --filter @agentos/api --filter @agentos/command-center --filter @agentos/gateway --filter @agentos/worker dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "agentos:validate-profiles": "node .agentos/scripts/validate-agent-profiles.mjs",
    "agentos:bench-profiles": "node .agentos/scripts/bench-agent-profiles.mjs",
    "agentos:bench-pipeline": "node .agentos/scripts/bench-pipeline.mjs",
    "agentos:bench-report": "node .agentos/scripts/bench-report.mjs",
    "agentos:bench-baseline": "node .agentos/scripts/bench-baseline.mjs",
    "mission:smoke": "node scripts/mission-execution-smoke.mjs",
    "agentos:optimize-hints": "node .agentos/scripts/optimize-agent-hints.mjs",
    "agentos:min-maxed-profiles": "node .agentos/scripts/apply-min-maxed-profiles.mjs",
    "memory:migrate-wiki": "node scripts/migrate-memory-to-wiki.mjs",
    "wiki:rebuild-manifest": "tsx scripts/rebuild-wiki-manifest.mjs",
    "wiki:index-repo": "tsx scripts/wiki-index-repo.mjs",
    "wiki:sync-cursor": "tsx scripts/wiki-sync-cursor.mjs",
    "wiki:sync-chatgpt": "tsx scripts/wiki-sync-chatgpt.mjs",
    "wiki:benchmark": "tsx scripts/wiki-memory-benchmark.mjs",
    "sanitize:check": "node scripts/sanitize-agentos.mjs",
    "env:check": "node scripts/validate-env.mjs",
    "db:migrate": "tsx scripts/db-migrate.mjs",
    "db:seed": "tsx scripts/db-seed.mjs",
    "db:reset": "tsx scripts/db-reset.mjs",
    "discord:bootstrap": "tsx scripts/bootstrap-discord-guild.ts",
    "discord:restructure": "tsx scripts/restructure-discord-guild.ts",
    "discord:sync-roles": "tsx scripts/sync-discord-roles.ts",
    "discord:interactions-mode": "tsx scripts/discord-interactions-mode.mjs",
    "discord:post-guides": "tsx scripts/post-discord-channel-guides.ts",
    "discord:kick-bots": "tsx scripts/kick-discord-bots.ts",
    "discord:sync-commands": "tsx scripts/sync-discord-commands.ts",
    "discord:smoke": "node apps/api/src/discord-smoke.mjs",
    "discord:smoke:full": "node apps/api/src/discord-smoke-full.mjs",
    "discord:live-smoke": "node apps/api/src/discord-live-smoke.mjs",
    "discord:setup-operator-channel": "tsx scripts/setup-operator-command-channel.ts",
    "discord:setup-cursor-channel": "tsx scripts/setup-cursor-channel.ts",
    "discord:post-brief": "tsx apps/api/src/discord-post-brief.mjs",
    "discord:post-spine-summary": "tsx apps/api/src/discord-post-spine-summary.mjs",
    "spine:demo": "node scripts/spine-demo.mjs",
    "spine:test": "node scripts/spine-test-and-report.mjs",
    "spine:validate": "node scripts/spine-test-and-report.mjs && node scripts/spine-demo.mjs",
    "smoke:full": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-full.ps1",
    "tunnel:repair": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/repair-cloudflare-tunnel.ps1",
    "dev:api": "pnpm --filter @agentos/api dev",
    "dev:stack": "pnpm --parallel --filter @agentos/command-center --filter @agentos/gateway --filter @agentos/worker dev",
    "control": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/agentos-control.ps1",
    "stack:background": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/agentos-background.ps1 -Action Start",
    "stack:restart": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/agentos-background.ps1 -Action Restart",
    "stack:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/agentos-background.ps1 -Action Stop",
    "stack:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/agentos-background.ps1 -Action Status",
    "install:autostart": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-agentos-autostart.ps1",
    "uninstall:autostart": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-agentos-autostart.ps1 -Uninstall",
    "demo": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/demo.ps1",
    "discord:test": "pnpm --filter @agentos/api exec vitest run src/discord src/discord-auth.test.ts src/auth-pages.test.ts",
    "test:e2e": "playwright test",
    "demo:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/demo-smoke.ps1",
    "acceptance:gate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/acceptance-gate.ps1",
    "dev:scheduler": "pnpm --filter @agentos/scheduler dev",
    "scoping:form": "powershell -NoProfile -Command \"Start-Process (Resolve-Path 'docs/demo/scoping-form/index.html').Path\"",
    "scoping:form:serve": "npx --yes serve@14 docs/demo/scoping-form -l 3456",
    "project:wave": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/project-wave-runner.ps1 -Action start",
    "project:wave:next": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/project-wave-runner.ps1 -Action next",
    "project:wave:prompt": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/project-wave-runner.ps1 -Action prompt",
    "project:wave:status": "node scripts/project-wave-runner.mjs status",
    "project:wave:reset": "node scripts/project-wave-runner.mjs reset",
    "project:wave:list": "node scripts/project-wave-runner.mjs list",
    "project:wave:run": "node scripts/project-wave-runner.mjs run",
    "project:wave:run-all": "node scripts/run-project-wave-auto.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
