# AgentOS functional profile — copy snippets into .env for real execution + hardened API.
# See docs/functional-profile.md

AGENTOS_API_REQUIRE_AUTH=true
AGENTOS_SESSION_MAX_AGE_SECONDS=2592000
# AGENTOS_CORS_ORIGINS=https://flous.dev,http://localhost:3000

FEATURE_AGENT_LLM=true
FEATURE_OLLAMA=true
AGENTOS_MODEL_PROVIDER=ollama
AGENTOS_MOCK_PIPELINE=false

FEATURE_TOOL_EXECUTION=true

AGENTOS_BUDGET_DAILY_USD=5
AGENTOS_BUDGET_HARD_STOP=true

FEATURE_LITELLM_PROXY=false

# Functionalization loop (OpenAI tries first; falls back to Cursor SDK on quota errors)
AGENTOS_FUNCTIONAL_DRIVER=openai
AGENTOS_FUNCTIONAL_OPENAI_MODEL=gpt-4o-mini
AGENTOS_FUNCTIONAL_MODEL=default
