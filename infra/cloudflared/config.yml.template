# Copy to %USERPROFILE%\.cloudflared\config.yml after running scripts/setup-cloudflare-tunnel.ps1
# Replace TUNNEL_ID with the UUID from: cloudflared tunnel list

tunnel: TUNNEL_ID
credentials-file: C:\Users\gaged\.cloudflared\TUNNEL_ID.json

ingress:
  - hostname: api.flous.dev
    service: http://127.0.0.1:8787
  - hostname: app.flous.dev
    service: http://127.0.0.1:3000
  - service: http_status:404
