{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@agentos/agents": ["packages/agents/src/index.ts"],
      "@agentos/llm-router": ["packages/llm-router/src/index.ts"],
      "@agentos/memory": ["packages/memory/src/index.ts"],
      "@agentos/orchestrator": ["packages/orchestrator/src/index.ts"],
      "@agentos/persistence": ["packages/persistence/src/index.ts"],
      "@agentos/runtime": ["packages/runtime/src/index.ts"],
      "@agentos/sandbox": ["packages/sandbox/src/index.ts"],
      "@agentos/shared": ["packages/shared/src/index.ts"],
      "@agentos/token-manager": ["packages/token-manager/src/index.ts"],
      "@agentos/ui": ["packages/ui/src/index.ts"],
      "@agentos/app-generator": ["packages/app-generator/src/index.ts"],
      "@agentos/app-generator/templates/agentos-forge/sample-data": [
        "packages/app-generator/templates/agentos-forge/sample-data.ts"
      ]
    }
  }
}
