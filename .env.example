AGENTOS_APP_NAME=AgentOS
AGENTOS_DASHBOARD_NAME=AgentOS Command Center
AGENTOS_ENV=development

AGENTOS_API_PORT=8787
AGENTOS_GATEWAY_PORT=8790
AGENTOS_COMMAND_CENTER_PORT=3000

DATABASE_URL=postgresql://agentos:agentos@localhost:5432/agentos
REDIS_URL=redis://localhost:6379

AGENTOS_MODEL_PROVIDER=ollama
AGENTOS_DEFAULT_MODEL=qwen2.5-coder:7b
FEATURE_OLLAMA=true
FEATURE_OLLAMA_CLASSIFIER=false
# Enable LLM-enhanced specialist summaries on mock_local lane (default false)
FEATURE_AGENT_LLM=false
# Block release when implementer made changes without operator approval (default true)
AGENTOS_NO_SELF_APPROVAL=true
# Implementer dispatch: gateway (default) | cursor | mock
AGENTOS_IMPLEMENTER_MODE=gateway
AGENTOS_IMPLEMENTER_DISPATCH=true
# tier2 metadata (default) | external (LLM via FEATURE_OLLAMA / FEATURE_AGENT_LLM) | false
AGENTOS_CLASSIFIER_TIER2=external
AGENTOS_IMPLEMENTER_APPLY_PATCHES=true
AGENTOS_MEMORY_DECAY=true
# Factory-style linked memory wiki
FEATURE_MEMORY_WIKI=true
AGENTOS_MEMORY_WIKI_WRITE=true
# Continuous Cursor chat → wiki sync (requires FEATURE_MEMORY_WIKI=true)
AGENTOS_CURSOR_WIKI_SYNC=false
# Optional override; auto-detected from ~/.cursor/projects when unset
AGENTOS_CURSOR_TRANSCRIPTS_DIR=
AGENTOS_CURSOR_WIKI_SYNC_INTERVAL_MS=60000
# OG ChatGPT planning board → wiki (manual: pnpm wiki:sync-chatgpt; drop exports in .agentos/imports/chatgpt/)
FEATURE_DISCORD=true
# Post #round-table debrief with executed agents only after mission completes
AGENTOS_DISCORD_BRIEFING_ON_COMPLETE=true
# House visits in ◈ NEIGHBORHOOD (invite, chat, wiki journal append)
AGENTOS_DISCORD_HOUSE_VISITS=true
FEATURE_DEMO_MODE=true
FEATURE_CLOUD_PROVIDERS=false
FEATURE_TOOL_EXECUTION=false
AGENTOS_TOOL_MAX_ITERATIONS=32
AGENTOS_TOOL_MAX_MINUTES=30
AGENTOS_FIX_VERIFY_RETRIES=3
AGENTOS_FIX_VERIFY_COMMAND=pnpm test
AGENTOS_SEMGREP_REQUIRED=true
AGENTOS_SEMGREP_GATE=true
FEATURE_LLM_TOOL_LOOP=false
FEATURE_TASK_SPAWN=false

AGENTOS_REQUIRE_HUMAN_APPROVAL=true
# Release: autopilot commit/PR when upstream gates pass (set false to disable gh pr)
AGENTOS_AUTOPILOT_RELEASE=true
AGENTOS_RELEASE_REQUIRE_HUMAN_APPROVAL=false
# Set true to skip gh pr create during autopilot release
# AGENTOS_SKIP_GH_PR=false
AGENTOS_SANITIZATION_MODE=strict

AGENTOS_DAILY_BUDGET_USD=2
AGENTOS_MONTHLY_BUDGET_USD=20
AGENTOS_WARNING_THRESHOLD_PERCENT=80
AGENTOS_HARD_STOP_ENABLED=true

AGENTOS_GITHUB_REPO=GageDush/AgentOS
AGENTOS_CURSOR_BILLING_DAY=1

AUTH_PROVIDER=discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_OAUTH_REDIRECT_URI=http://127.0.0.1:8787/auth/discord/callback
# Production OAuth callback (option C: register both in Discord portal)
DISCORD_OAUTH_REDIRECT_URI_PROD=https://api.flous.dev/auth/discord/callback
DISCORD_OAUTH_SCOPES=identify
# Set DISCORD_LIVE_SMOKE=1 to post a test message to #status during discord:smoke:full
AGENTOS_PUBLIC_APP_URL=https://flous.dev
AGENTOS_OAUTH_SUCCESS_REDIRECT=https://flous.dev
AGENTOS_API_BASE_URL=https://api.flous.dev
NEXT_PUBLIC_AGENTOS_API_URL=https://api.flous.dev
# Public HTTPS base for agent portraits in Discord (API serves /media/agents/)
AGENTOS_DISCORD_AVATAR_BASE_URL=https://api.flous.dev/media/agents
# Public HTTPS base for agent portraits in Discord (must be reachable by Discord; API serves /media/agents/)
AGENTOS_DISCORD_AVATAR_BASE_URL=https://api.flous.dev/media/agents
# Discord #cursor channel — Cursor SDK bridge (Cursor Dashboard → Integrations)
CURSOR_API_KEY=
AGENTOS_CURSOR_REPO_CWD=
AGENTOS_CURSOR_MODEL=composer-2.5
AGENTOS_FUNCTIONAL_MODEL=default
# functionalization loop driver: openai (fast, uses OPENAI_API_KEY) | cursor (Cursor SDK) | per-task shell
AGENTOS_FUNCTIONAL_DRIVER=openai
AGENTOS_FUNCTIONAL_OPENAI_MODEL=gpt-4o-mini
FEATURE_DISCORD_CURSOR=true
# Local Next dev proxies /agentos-api to this target (defaults to http://127.0.0.1:8787)
# AGENTOS_API_PROXY_TARGET=http://127.0.0.1:8787
AGENTOS_COOKIE_DOMAIN=.flous.dev
# Keep operators signed in (seconds). Default: 365 days. Sliding refresh on /auth/me.
AGENTOS_SESSION_MAX_AGE_SECONDS=31536000
# Require Discord session on non-public API routes (set true for functional profile / production).
AGENTOS_API_REQUIRE_AUTH=false
# Comma-separated browser origins for credentialed CORS (unset = reflect any origin in dev).
# AGENTOS_CORS_ORIGINS=https://flous.dev,http://localhost:3000
# Mutating API rate limit per operator/IP (default 120 requests / 60s).
# AGENTOS_MUTATE_RATE_LIMIT_MAX=120
# AGENTOS_MUTATE_RATE_LIMIT_WINDOW_MS=60000
# HTTP /discord/bootstrap and /discord/restructure (also require session when AGENTOS_API_REQUIRE_AUTH=true).
FEATURE_DISCORD_ADMIN_ROUTES=false
# Optional override: none | lax | strict (auto: none when AGENTOS_COOKIE_DOMAIN is set)
# AGENTOS_COOKIE_SAMESITE=none
# Local-only dev (register both local + prod redirects in Discord portal):
# DISCORD_OAUTH_REDIRECT_URI=http://127.0.0.1:8787/auth/discord/callback
# AGENTOS_PUBLIC_APP_URL=http://localhost:3000
# AGENTOS_OAUTH_SUCCESS_REDIRECT=http://127.0.0.1:8787/auth/success
# app.flous.dev and agentos.flous.dev also serve the dashboard; flous.dev is canonical.
SESSION_SECRET=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
DISCORD_PUBLIC_KEY=
# Your Discord user ID — required for private #operator-command and #cursor channels
DISCORD_OWNER_USER_ID=
# Default ready/busy indicator + brief posts: cursor (default when #cursor exists) | operator-command
# DISCORD_OPERATOR_PROMPT_CHANNEL=cursor
# Legacy alias used by some scripts if OWNER is unset
DISCORD_ADMIN_USER_ID=
# Optional extra operator IDs (comma-separated)
DISCORD_OPERATOR_USER_IDS=
# Discord Developer Portal → Bot → Privileged Gateway Intents: enable MESSAGE CONTENT
# for direct LLM chat in #general. Interactions (slash + buttons) need ONE of:
# - Interactions Endpoint URL (https://api.flous.dev/discord/interactions) + DISCORD_PUBLIC_KEY above
# - OR leave Interactions Endpoint URL empty and handle via Gateway while the API is running
# Public key: Discord Developer Portal → General → Public Key

# IcePanel REST API — auto-populate diagrams (MCP cannot layout diagrams)
# Org Settings → API keys → create key with write access
# ICEPANEL_API_KEY=
# ICEPANEL_LANDSCAPE_ID=j6f0TMmnvqS5ka7D2O27
# ICEPANEL_CONTEXT_DIAGRAM_ID=epq3Q0nOsO8SIfiTOiHR

# ── LLM Router / LiteLLM sidecar (packages/llm-router) ──────────────────────
# Local-first by default: Ollama handles routine work; cloud lanes only run
# through LiteLLM when enabled AND quota + budget gates allow. Inference still
# costs money on paid providers (billed to whoever owns the key = you).
FEATURE_LITELLM_PROXY=false            # true when the LiteLLM sidecar is running
AGENTOS_LITELLM_BASE_URL=http://127.0.0.1:4000
# AGENTOS_LITELLM_MASTER_KEY=          # optional, if your LiteLLM proxy requires auth
AGENTOS_LLM_ROUTER_MODE=local-first    # local-first | cloud-ok | litellm-only
AGENTOS_LLM_DEFAULT_ALIAS=agentos-coder
# OPENAI_API_KEY / ANTHROPIC_API_KEY above feed the LiteLLM config template.
OPENROUTER_API_KEY=                    # optional aggregator BYOK (not required)
# Budgets (USD) — wired into evaluateBudget before any paid call:
# AGENTOS_DAILY_BUDGET_USD=2
AGENTOS_MONTHLY_BUDGET_USD=20
AGENTOS_HARD_STOP_ENABLED=true
