AGENTOS_APP_NAME=AgentOS
AGENTOS_DASHBOARD_NAME=AgentOS Command Center
AGENTOS_ENV=development

AGENTOS_API_PORT=8787
AGENTOS_GATEWAY_PORT=8790
AGENTOS_COMMAND_CENTER_PORT=3000

DATABASE_URL=postgresql://agentos:agentos@localhost:5432/agentos
REDIS_URL=redis://localhost:6379

AGENTOS_MODEL_PROVIDER=ollama
AGENTOS_DEFAULT_MODEL=qwen2.5-coder:7b
FEATURE_OLLAMA=true
FEATURE_DISCORD=true
FEATURE_DEMO_MODE=true
FEATURE_CLOUD_PROVIDERS=false
FEATURE_TOOL_EXECUTION=false

AGENTOS_REQUIRE_HUMAN_APPROVAL=true
AGENTOS_SANITIZATION_MODE=strict

AGENTOS_DAILY_BUDGET_USD=2
AGENTOS_MONTHLY_BUDGET_USD=20
AGENTOS_WARNING_THRESHOLD_PERCENT=80
AGENTOS_HARD_STOP_ENABLED=true

AGENTOS_GITHUB_REPO=GageDush/AgentOS
AGENTOS_CURSOR_BILLING_DAY=1

AUTH_PROVIDER=discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_OAUTH_REDIRECT_URI=http://127.0.0.1:8787/auth/discord/callback
DISCORD_OAUTH_SCOPES=identify
AGENTOS_PUBLIC_APP_URL=https://flous.dev
AGENTOS_OAUTH_SUCCESS_REDIRECT=https://flous.dev
AGENTOS_API_BASE_URL=https://api.flous.dev
NEXT_PUBLIC_AGENTOS_API_URL=https://api.flous.dev
AGENTOS_COOKIE_DOMAIN=.flous.dev
# Local-only dev (register both local + prod redirects in Discord portal):
# DISCORD_OAUTH_REDIRECT_URI=http://127.0.0.1:8787/auth/discord/callback
# AGENTOS_PUBLIC_APP_URL=http://localhost:3000
# AGENTOS_OAUTH_SUCCESS_REDIRECT=http://127.0.0.1:8787/auth/success
# app.flous.dev and agentos.flous.dev also serve the dashboard; flous.dev is canonical.
SESSION_SECRET=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
DISCORD_PUBLIC_KEY=
# Discord Developer Portal → Bot → Privileged Gateway Intents: enable MESSAGE CONTENT
# for direct LLM chat in #general. Interactions (slash + buttons) need ONE of:
# - Interactions Endpoint URL (https://api.flous.dev/discord/interactions) + DISCORD_PUBLIC_KEY above
# - OR leave Interactions Endpoint URL empty and handle via Gateway while the API is running
# Public key: Discord Developer Portal → General → Public Key
